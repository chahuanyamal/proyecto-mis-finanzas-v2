# ── App ──
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:1510
INTERNAL_API_URL=http://backend:8000

# ── Database ──
DATABASE_URL=postgresql+asyncpg://finanzas:finanzas@postgres:5432/finanzas
POSTGRES_DB=finanzas
POSTGRES_USER=finanzas
POSTGRES_PASSWORD=finanzas

# ── Auth ──
SECRET_KEY=reemplazar-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
COOKIE_SECURE=false

# ── Admin ──
ADMIN_EMAIL=admin@finanzas.local
ADMIN_FULL_NAME=Admin
ADMIN_PASSWORD=admin123
